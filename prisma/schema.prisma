generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  role      Role     @default(EMPLOYEE)
  createdAt DateTime @default(now())

  requests ExpenseRequest[]
  approvals Approval[]
}

model ExpenseRequest {
  id         Int      @id @default(autoincrement())
  userId     Int
  date       DateTime
  from       String
  to         String
  distance   Float
  amount     Float
  purpose    String
  status     Status   @default(PENDING)
  receiptUrl String?
  createdAt  DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id])
  approvals Approval[]
}

model Approval {
  id        Int      @id @default(autoincrement())
  requestId Int
  managerId Int
  action    Action
  comment   String?
  createdAt DateTime @default(now())

  request ExpenseRequest @relation(fields: [requestId], references: [id])
  manager User           @relation(fields: [managerId], references: [id])
}

enum Role {
  EMPLOYEE
  MANAGER
}

enum Status {
  PENDING
  APPROVED
  REJECTED
}

enum Action {
  APPROVED
  REJECTED
}
